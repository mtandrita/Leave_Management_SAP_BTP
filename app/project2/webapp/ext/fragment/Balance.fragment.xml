<core:FragmentDefinition xmlns:chart="sap.fe.macros.chart"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="sapUiMediumMargin">

        <Title text="Leave Information"/>

        <!-- Leave Balance -->
        <Panel
            headerText="Leave Balance"
            class="sapUiSmallMarginTop">

            <Table>

                <columns>
                    <Column>
                        <Text text="Leave Type"/>
                    </Column>

                    <Column>
                        <Text text="Balance"/>
                    </Column>
                </columns>

                <items>

                    <ColumnListItem>
                        <cells>
                            <Text text="Casual Leave"/>
                            <ObjectStatus
                                text="16 Days"
                                state="Success"/>
                        </cells>
                    </ColumnListItem>

                    <ColumnListItem>
                        <cells>
                            <Text text="Sick Leave"/>
                            <ObjectStatus
                                text="6 Days"
                                state="Warning"/>
                        </cells>
                    </ColumnListItem>

                </items>

            </Table>

        </Panel>

        <!-- Leave History -->
        <Panel
            headerText="Leave History"
            class="sapUiSmallMarginTop">

            <Table>

                <columns>

                    <Column>
                        <Text text="Type"/>
                    </Column>

                    <Column>
                        <Text text="From"/>
                    </Column>

                    <Column>
                        <Text text="To"/>
                    </Column>

                    <Column>
                        <Text text="Status"/>
                    </Column>

                </columns>

                <items>

                    <ColumnListItem>
                        <cells>
                            <Text text="Casual Leave"/>
                            <Text text="10-Jun-2026"/>
                            <Text text="12-Jun-2026"/>
                            <ObjectStatus
                                text="Approved"
                                state="Success"/>
                        </cells>
                    </ColumnListItem>

                    <ColumnListItem>
                        <cells>
                            <Text text="Sick Leave"/>
                            <Text text="20-Jun-2026"/>
                            <Text text="21-Jun-2026"/>
                            <ObjectStatus
                                text="Pending"
                                state="Warning"/>
                        </cells>
                    </ColumnListItem>

                </items>

            </Table>

        </Panel>

        <!-- Warning Button -->
        
    </VBox>
        
</core:FragmentDefinition>