<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="sapUiMediumMargin">

        <Title text="Leave History"/>

        <Table id="leaveHistoryTable">

            <columns>

                <Column>
                    <Text text="Leave Type"/>
                </Column>

                <Column>
                    <Text text="From"/>
                </Column>

                <Column>
                    <Text text="To"/>
                </Column>

                <Column>
                    <Text text="Status"/>
                </Column>

            </columns>

        </Table>

    </VBox>

</core:FragmentDefinition>