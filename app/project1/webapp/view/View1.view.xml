<mvc:View
    xmlns:upload="sap.m.upload"
    controllerName="project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    displayBlock="true">

    <App id="app" fitContainer="true">
        <pages>
            <Page id="page" title="Employee Leave Portal" showHeader="false" scrolling="true">
                <content>
                    
                    <VBox class="sapUiMediumMargin customBackground">

                        <HBox justifyContent="End" alignItems="Center" width="100%">
                            <HBox class="notificationContainer">
                                <Button
                                    id="notificationBell"
                                    icon="sap-icon://bell"
                                    press="onOpenNotifications"
                                    type="Transparent"
                                    class="notificationBell"/>
                                <Text
                                    id="notificationBadge"
                                    text="0"
                                    visible="false"
                                    class="notificationBadge"/>
                            </HBox>
                        </HBox>

                       <!-- RECTANGULAR CARD CONTAINER -->
<VBox class="sapUiMediumMarginTop dashboardCard">
    <!-- Card Header Section -->
    <HBox alignItems="Start" class="cardHeaderBar sapUiSmallMarginBottom">
        <core:Icon src="sap-icon://lead" class="cardHeaderIcon sapUiSmallMarginEnd"/>
        <Title text="Leave Balance Overview" level="H2" class="cardHeaderText"/>
    </HBox>

    <!-- Content Row -->
    <HBox
    justifyContent="SpaceAround"
    width="100%"
    wrap="Wrap"
    class="leaveCardsContainer">

    <!-- Casual -->
    <VBox class="balanceTile casualCard">

        <HBox alignItems="Center" width="100%">

            <core:Icon
                src="sap-icon://employee-pane"
                class="leaveTileIcon casualIcon"/>

            <VBox class="sapUiSmallMarginBegin">

                <Title
                    text="Casual Leave"
                    level="H4"
                    class="leaveTitle"/>

                <HBox alignItems="End">

                    <Text
                        id="casualBalanceTile"
                        text="{employeeModel>/casualBalance}"
                        class="leaveValue"/>

                    <Text
                        text="Days"
                        class="leaveDays"/>

                </HBox>

                <Text
                    text="Available"
                    class="leaveAvailable"/>

            </VBox>

        </HBox>

    </VBox>

    <!-- Sick -->
    <VBox class="balanceTile sickCard">

        <HBox alignItems="Center">

            <core:Icon
                src="sap-icon://doctor"
                class="leaveTileIcon sickIcon"/>

            <VBox class="sapUiSmallMarginBegin">

                <Title
                    text="Sick Leave"
                    level="H4"
                    class="leaveTitle"/>

                <HBox alignItems="End">

                    <Text
                        id="sickBalanceTile"
                        text="{employeeModel>/sickBalance}"
                        class="leaveValue"/>

                    <Text
                        text="Days"
                        class="leaveDays"/>

                </HBox>

                <Text
                    text="Available"
                    class="leaveAvailable"/>

            </VBox>

        </HBox>

    </VBox>

    <!-- Paid -->
    <VBox class="balanceTile paidCard">

        <HBox alignItems="Center">

            <core:Icon
                src="sap-icon://money-bills"
                class="leaveTileIcon paidIcon"/>

            <VBox class="sapUiSmallMarginBegin">

                <Title
                    text="Paid Leave"
                    level="H4"
                    class="leaveTitle"/>

                <HBox alignItems="End">

                    <Text
                        id="paidLeaveBalanceTile"
                        text="{employeeModel>/paidLeaveBalance}"
                        class="leaveValue"/>

                    <Text
                        text="Days"
                        class="leaveDays"/>

                </HBox>

                <Text
                    text="Available"
                    class="leaveAvailable"/>

            </VBox>

        </HBox>

    </VBox>

</HBox>
</VBox>
                         <VBox class="sapUiMediumMarginTop policyCard">

    <HBox alignItems="Center">
        <core:Icon
            src="sap-icon://message-information"
            class="cardHeaderIcon sapUiSmallMarginEnd"/>

        <Title
            text="Leave Policies"
            level="H3"/>
    </HBox>

    <Text
        text="Leave Policy: Employees are entitled to 18 Casual Leaves, 7 Sick Leaves and 12 Paid Leaves per financial year. Half-Day Leave is permitted for either the Morning or Afternoon session and is counted as 0.5 day."
        wrapping="true"
        class="sapUiSmallMarginTop"/>

</VBox>

                        <VBox class="sapUiMediumMarginTop requestCard">

    <HBox alignItems="Center" class="cardHeaderBar">
        <core:Icon
            src="sap-icon://calendar"
            class="cardHeaderIcon sapUiSmallMarginEnd"/>

        <Title
            text="Request Overview"
            level="H2"
            class="cardHeaderText"/>
    </HBox>

    <HBox
        justifyContent="SpaceBetween"
        alignItems="Start"
        wrap="Wrap">

        <!-- CALENDAR AREA -->
        <HBox
            width="75%"
            justifyContent="Center"
            wrap="Wrap">

            <unified:Calendar
                id="calendar1"
                width="340px"
                intervalSelection="true"
                select="onCalendarSelect"
                class="sapUiSmallMarginEnd dashboardCalendar"/>

            <unified:Calendar
                id="calendar2"
                width="340px"
                intervalSelection="true"
                select="onCalendarSelect"
                class="dashboardCalendar"/>

        </HBox>

        <!-- RIGHT SIDE -->
        <VBox width="20%" class="legendPanel">

            <Title text="Legend" level="H4"/>

            <ObjectStatus
                text="Approved"
                state="Success"
                class="sapUiTinyMarginTop"/>

            <ObjectStatus
                text="Pending"
                state="Warning"
                class="sapUiTinyMarginTop"/>

            <ObjectStatus
                text="Rejected"
                state="Error"
                class="sapUiTinyMarginTop"/>

            <ToolbarSeparator class="sapUiMediumMarginTop"/>

            <Text
                text="Need to apply for leave?"
                class="sapUiSmallMarginTop"/>

            <Button
    text="Apply Leave"
    type="Emphasized"
    width="100%"
    icon="sap-icon://paper-plane"
    iconFirst="false"
    class="sapUiSmallMarginTop customApplyBtn"
    press=".onApplyLeave"/>

<Button
    text="Leave History"
    width="100%"
    icon="sap-icon://history"
    iconFirst="false"
    class="sapUiSmallMarginTop customHistoryBtn"
    press=".onOpenHistory"/>

        </VBox>

    </HBox>

</VBox>

                    </VBox>
                </content>

                <dependents>
                    <Dialog id="notificationDialog" showHeader="false" contentWidth="550px" class="customNotificationDialog">
    <content>
        <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%" class="dialogHeaderArea sapUiSmallMarginBottom">
            <HBox alignItems="Center">
                <Button icon="sap-icon://bell" type="Transparent" class="headerIconBell" enabled="false"/>
                <Title text="Notifications" level="H2" class="headerDialogTitle sapUiTinyMarginBegin"/>
            </HBox>
            <Button icon="sap-icon://decline" type="Transparent" press="onCloseNotifications" class="circleCloseButton"/>
        </HBox>

        <List id="notificationList" items="{path: '/Notification', sorter: {path: 'createdAt', descending: true}}" separators="None">
            <items>
                <CustomListItem class="notificationStreamCard">
                    <HBox width="100%" alignItems="Start" class="cardInnerContent">
                        
                        <VBox width="75%" class="messageBodyBox">
                            <Text text="{createdAt}" class="systemTimestampText sapUiTinyMarginBottom"/>
                            
                            <Text text="{message}" 
                                  wrapping="true" 
                                  class="notificationMessageContent {= ${path: 'isRead', targetType: 'any'} === true ? 'readNormal' : 'unreadBold' }"/>
                        </VBox>

                        <VBox alignItems="End" class="metaRightBox" style="margin-left: auto;">
                            <Text text="{status}" class="statusBadgePill {= ${path: 'status', targetType: 'any'} === 'Approved' ? 'badgeApproved' : ${path: 'status', targetType: 'any'} === 'Rejected' ? 'badgeRejected' : 'badgeWarning' }"/>
                        </VBox>

                    </HBox>
                </CustomListItem>
            </items>
        </List>
    </content>

    <endButton>
        <Button text="Close" type="Transparent" press="onCloseNotifications" class="footerCloseActionBtn"/>
    </endButton>
</Dialog>
                   <Dialog id="historyDialog" showHeader="false" contentWidth="750px" class="customHistoryDialog">
    <content>
        <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%" class="dialogHeaderArea sapUiSmallMarginBottom">
            <HBox alignItems="Center">
                <Button icon="sap-icon://calendar" type="Transparent" class="headerIconHistory" enabled="false"/>
                <Title text="Leave History" level="H2" class="headerDialogTitle sapUiTinyMarginBegin"/>
            </HBox>
            <Button icon="sap-icon://decline" type="Transparent" press="onCloseHistory" class="circleCloseButton"/>
        </HBox>

        <Table id="historyTable" items="{path: '/LeaveRequest'}" class="customHistoryTable">
            <columns>
                <Column width="35%"><Text text="Leave Type" class="columnHeaderText"/></Column>
                <Column><Text text="From" class="columnHeaderText"/></Column>
                <Column><Text text="To" class="columnHeaderText"/></Column>
                <Column hAlign="End"><Text text="Status" class="columnHeaderText"/></Column>
            </columns>
            <items>
                <ColumnListItem class="historyRowItem">
                    <cells>
                        <HBox alignItems="Center" class="leaveTypeCellBox">
                            <VBox class="historyTypeIconBox {= ${leaveType} === 'Casual Leave' ? 'historyCasualIcon' : ${leaveType} === 'Sick Leave' ? 'historySickIcon' : 'historyPaidIcon' } sapUiSmallMarginEnd">
                                <core:Icon src="{= ${leaveType} === 'Casual Leave' ? 'sap-icon://umbrella-beach' : ${leaveType} === 'Sick Leave' ? 'sap-icon://doctor' : 'sap-icon://money-bills' }"/>
                            </VBox>
                            <Text text="{leaveType}" class="rowMainText fontSemiBold"/>
                        </HBox>

                        <Text text="{startDate}" class="rowMainText textMutedColor"/>

                        <Text text="{endDate}" class="rowMainText textMutedColor"/>

                        <ObjectStatus text="{status}" 
                                      state="{= ${status} === 'Approved' ? 'Success' : ${status} === 'Rejected' ? 'Error' : 'Warning' }"
                                      class="historyStatusBadge"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </content>

    <endButton>
        <Button text="Close" type="Emphasized" press="onCloseHistory" class="dialogFooterBlueBtn"/>
    </endButton>
</Dialog>

                    <Dialog id="leaveDialog" showHeader="false" contentWidth="600px" class="customApplyLeaveDialog">
    <content>
        <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%" class="dialogHeaderArea sapUiSmallMarginBottom">
            <HBox alignItems="Center">
                <Button icon="sap-icon://calendar" type="Transparent" class="headerIconApply" enabled="false"/>
                <VBox class="sapUiTinyMarginBegin">
                    <Title text="Apply Leave" level="H2" class="headerDialogTitle"/>
                    <Text text="Fill in the details below to submit your leave request" class="headerSubtitleText"/>
                </VBox>
            </HBox>
            <Button icon="sap-icon://decline" type="Transparent" press="onCloseDialog" class="circleCloseButton"/>
        </HBox>

        <VBox class="formLayoutBody sapUiSmallMarginTop">
            
            <Label text="Employee" class="customFormLabel"/>
            <HBox width="100%" alignItems="Center" class="inputIconWrapper sapUiSmallMarginBottom">
                <core:Icon src="sap-icon://person-placeholder" class="inputFieldInlineIcon"/>
                <Input value="Tandrita Mukherjee" editable="false" class="customFormInput textMuted"/>
            </HBox>

            <Label text="Leave Type" required="true" class="customFormLabel"/>
<Select id="leaveTypeSelect" 
        width="100%" 
        valueIcon="sap-icon://folder" 
        class="customFormSelectWithIcon">
    <items>
        <core:Item text="Casual Leave"/>
        <core:Item text="Sick Leave"/>
        <core:Item text="Paid Leave"/>
    </items>
</Select>

            <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                <VBox width="48%">
                    <Label text="From Date" required="true" class="customFormLabel"/>
                    <DatePicker id="fromDate" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" placeholder="Select from date" class="customFormDatePicker"/>
                </VBox>
                <VBox width="48%">
                    <Label text="To Date" required="true" class="customFormLabel"/>
                    <DatePicker id="toDate" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" placeholder="Select to date" class="customFormDatePicker"/>
                </VBox>
            </HBox>

            <Label text="Half Day Leave" class="customFormLabel"/>
            <CheckBox id="halfDayBox" text="Apply for Half Day" select=".onHalfDayToggle" class="customFormCheckbox sapUiTinyMarginBottom"/>

            <VBox id="halfDayContainer" visible="false" class="sapUiSmallMarginBottom">
                <Label text="Select Session" class="customFormLabel"/>
                <SegmentedButton id="halfDayPeriod" class="customSegmentedButton">
                    <items>
                        <SegmentedButtonItem key="Morning" text="Morning"/>
                        <SegmentedButtonItem key="Afternoon" text="Afternoon"/>
                    </items>
                </SegmentedButton>
            </VBox>

            <HBox width="100%" class="infoCalloutBox sapUiSmallMarginBottom" alignItems="Start">
                <core:Icon src="sap-icon://message-information" class="calloutInfoIcon sapUiTinyMarginEnd"/>
                <Text text="Half-Day Leave is permitted for either the Morning or Afternoon session and is counted as 0.5 day." class="calloutInfoText"/>
            </HBox>

            <Label text="Reason" required="true" class="customFormLabel"/>
            <TextArea id="reasonText" rows="4" placeholder="Enter reason for leave" width="100%" class="customFormTextArea sapUiSmallMarginBottom"/>

            <Label text="Attachments (Optional)" class="customFormLabel"/>
            <unified:FileUploader 
                id="fileUploader" 
                multiple="true" 
                width="100%" 
                sameFilenameAllowed="false" 
                change=".onFileChange"
                placeholder="Choose files..."/>

        </VBox>
    </content>

    <buttons>
        <Button text="Submit" type="Emphasized" press=".onSubmitLeave" class="dialogFooterBlueBtn submitActionBtn"/>
        <Button text="Cancel" press="onCloseDialog" class="dialogFooterCancelBtn"/>
    </buttons>
</Dialog>
                </dependents>

            </Page>
        </pages>
    </App>
</mvc:View>